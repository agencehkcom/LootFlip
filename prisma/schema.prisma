generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  WEAPON
  ARMOR
  SPELL
}

enum ItemTrait {
  BURN
  FREEZE
  LIGHTNING
  SHADOW
  HEAL
  POISON
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum BattleMode {
  RANKED
  TUTORIAL
}

model User {
  id          String   @id @default(uuid())
  telegramId  String   @unique
  username    String?
  displayName String?
  elo         Int      @default(1000)
  trophies    Int      @default(0)
  goldBalance Int      @default(0)
  gemBalance  Int      @default(0)
  createdAt   DateTime @default(now())

  items      Item[]
  battlesAs1 Battle[] @relation("player1")
  battlesAs2 Battle[] @relation("player2")
  battlesWon Battle[] @relation("winner")
  chestState ChestState?
}

model Item {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  type        ItemType
  trait       ItemTrait
  rarity      Rarity
  bonusDamage Int
  isEquipped  Boolean   @default(false)
  tradeableAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([ownerId])
}

model ChestState {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id])
  stock      Int      @default(0)
  nextFreeAt DateTime @default(now())
}

model Battle {
  id        String     @id @default(uuid())
  player1Id String
  player2Id String
  winnerId  String?
  mode      BattleMode
  goldStake Int        @default(0)
  roundsData Json
  createdAt DateTime   @default(now())

  player1 User  @relation("player1", fields: [player1Id], references: [id])
  player2 User  @relation("player2", fields: [player2Id], references: [id])
  winner  User? @relation("winner", fields: [winnerId], references: [id])

  @@index([player1Id])
  @@index([player2Id])
}
