generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  WEAPON
  ARMOR
  SPELL
}

enum ItemTrait {
  BURN
  FREEZE
  LIGHTNING
  SHADOW
  HEAL
  POISON
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum BattleMode {
  RANKED
  TUTORIAL
}

enum League {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGEND
}

enum SeasonStatus {
  ACTIVE
  COMPLETED
}

enum Currency {
  GOLD
  GEM
}

enum ListingStatus {
  ACTIVE
  SOLD
  CANCELLED
  EXPIRED
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
  EXPIRED
}

enum ShopCategory {
  CHEST
  CONSUMABLE
  COSMETIC
}

enum CosmeticType {
  TITLE
  FRAME
  EFFECT
}

model User {
  id          String   @id @default(uuid())
  telegramId  String   @unique
  username    String?
  displayName String?
  elo         Int      @default(1000)
  trophies    Int      @default(0)
  goldBalance Int      @default(0)
  gemBalance  Int      @default(0)
  league      League   @default(BRONZE)
  createdAt   DateTime @default(now())

  potionCount Int      @default(0)

  items          Item[]
  battlesAs1     Battle[]        @relation("player1")
  battlesAs2     Battle[]        @relation("player2")
  battlesWon     Battle[]        @relation("winner")
  chestState     ChestState?
  seasonRewards  SeasonReward[]
  listings       MarketListing[] @relation("UserListings")
  offers         MarketOffer[]   @relation("UserOffers")
  purchases      Purchase[]
  cosmetics      Cosmetic[]
}

model Item {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  type        ItemType
  trait       ItemTrait
  rarity      Rarity
  bonusDamage Int
  isEquipped  Boolean   @default(false)
  isListed    Boolean   @default(false)
  tradeableAt DateTime?
  createdAt   DateTime  @default(now())

  listing MarketListing?

  @@index([ownerId])
  @@index([rarity, trait, type])
}

model ChestState {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id])
  stock      Int      @default(0)
  nextFreeAt DateTime @default(now())
}

model Battle {
  id        String     @id @default(uuid())
  player1Id String
  player2Id String
  winnerId  String?
  mode      BattleMode
  goldStake    Int        @default(0)
  eloChange    Int        @default(0)
  isBotMatch   Boolean    @default(false)
  potionUsedP1 Boolean    @default(false)
  potionUsedP2 Boolean    @default(false)
  roundsData   Json
  createdAt  DateTime   @default(now())

  player1 User  @relation("player1", fields: [player1Id], references: [id])
  player2 User  @relation("player2", fields: [player2Id], references: [id])
  winner  User? @relation("winner", fields: [winnerId], references: [id])

  @@index([player1Id])
  @@index([player2Id])
}

model Season {
  id        String       @id @default(uuid())
  weekStart DateTime
  weekEnd   DateTime
  status    SeasonStatus @default(ACTIVE)
  createdAt DateTime     @default(now())

  rewards SeasonReward[]

  @@unique([weekStart])
}

model SeasonReward {
  id        String    @id @default(uuid())
  seasonId  String
  season    Season    @relation(fields: [seasonId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  league    League
  rank      Int
  gemReward Int
  claimedAt DateTime?

  @@unique([seasonId, userId])
  @@index([userId])
}

model MarketListing {
  id        String        @id @default(cuid())
  sellerId  String
  seller    User          @relation("UserListings", fields: [sellerId], references: [id])
  itemId    String        @unique
  item      Item          @relation(fields: [itemId], references: [id])
  price     Int
  currency  Currency
  status    ListingStatus @default(ACTIVE)
  expiresAt DateTime
  createdAt DateTime      @default(now())

  offers MarketOffer[]

  @@index([sellerId])
  @@index([status, currency])
}

model MarketOffer {
  id         String      @id @default(cuid())
  listingId  String
  listing    MarketListing @relation(fields: [listingId], references: [id])
  buyerId    String
  buyer      User        @relation("UserOffers", fields: [buyerId], references: [id])
  offerPrice Int
  status     OfferStatus @default(PENDING)
  expiresAt  DateTime
  createdAt  DateTime    @default(now())

  @@index([listingId])
  @@index([buyerId])
}

model ShopItem {
  id           String       @id @default(cuid())
  category     ShopCategory
  name         String       @unique
  description  String
  basePrice    Int
  currency     Currency
  currentPrice Int
  isDynamic    Boolean      @default(false)
  metadata     Json?
  createdAt    DateTime     @default(now())

  purchases    Purchase[]
  priceHistory PriceHistory[]
}

model Purchase {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id])
  pricePaid  Int
  currency   Currency
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([shopItemId])
}

model PriceHistory {
  id         String   @id @default(cuid())
  shopItemId String
  shopItem   ShopItem @relation(fields: [shopItemId], references: [id])
  price      Int
  recordedAt DateTime @default(now())

  @@index([shopItemId, recordedAt])
}

model Cosmetic {
  id         String       @id @default(cuid())
  ownerId    String
  owner      User         @relation(fields: [ownerId], references: [id])
  type       CosmeticType
  name       String
  metadata   Json?
  equippedAt DateTime?
  createdAt  DateTime     @default(now())

  @@index([ownerId])
}

model CraftRecipe {
  id                String @id @default(cuid())
  fromRarity        Rarity
  toRarity          Rarity
  goldCost          Int
  materialsRequired Int

  @@unique([fromRarity, toRarity])
}
