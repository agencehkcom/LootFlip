generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ItemType {
  WEAPON
  ARMOR
  SPELL
}

enum ItemTrait {
  BURN
  FREEZE
  LIGHTNING
  SHADOW
  HEAL
  POISON
}

enum Rarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
  MYTHIC
}

enum BattleMode {
  RANKED
  TUTORIAL
}

enum League {
  BRONZE
  SILVER
  GOLD
  DIAMOND
  LEGEND
}

enum SeasonStatus {
  ACTIVE
  COMPLETED
}

model User {
  id          String   @id @default(uuid())
  telegramId  String   @unique
  username    String?
  displayName String?
  elo         Int      @default(1000)
  trophies    Int      @default(0)
  goldBalance Int      @default(0)
  gemBalance  Int      @default(0)
  league      League   @default(BRONZE)
  createdAt   DateTime @default(now())

  items         Item[]
  battlesAs1    Battle[]       @relation("player1")
  battlesAs2    Battle[]       @relation("player2")
  battlesWon    Battle[]       @relation("winner")
  chestState    ChestState?
  seasonRewards SeasonReward[]
}

model Item {
  id          String    @id @default(uuid())
  ownerId     String
  owner       User      @relation(fields: [ownerId], references: [id])
  type        ItemType
  trait       ItemTrait
  rarity      Rarity
  bonusDamage Int
  isEquipped  Boolean   @default(false)
  tradeableAt DateTime?
  createdAt   DateTime  @default(now())

  @@index([ownerId])
}

model ChestState {
  userId     String   @id
  user       User     @relation(fields: [userId], references: [id])
  stock      Int      @default(0)
  nextFreeAt DateTime @default(now())
}

model Battle {
  id        String     @id @default(uuid())
  player1Id String
  player2Id String
  winnerId  String?
  mode      BattleMode
  goldStake  Int        @default(0)
  eloChange  Int        @default(0)
  isBotMatch Boolean    @default(false)
  roundsData Json
  createdAt  DateTime   @default(now())

  player1 User  @relation("player1", fields: [player1Id], references: [id])
  player2 User  @relation("player2", fields: [player2Id], references: [id])
  winner  User? @relation("winner", fields: [winnerId], references: [id])

  @@index([player1Id])
  @@index([player2Id])
}

model Season {
  id        String       @id @default(uuid())
  weekStart DateTime
  weekEnd   DateTime
  status    SeasonStatus @default(ACTIVE)
  createdAt DateTime     @default(now())

  rewards SeasonReward[]

  @@unique([weekStart])
}

model SeasonReward {
  id        String    @id @default(uuid())
  seasonId  String
  season    Season    @relation(fields: [seasonId], references: [id])
  userId    String
  user      User      @relation(fields: [userId], references: [id])
  league    League
  rank      Int
  gemReward Int
  claimedAt DateTime?

  @@unique([seasonId, userId])
  @@index([userId])
}
